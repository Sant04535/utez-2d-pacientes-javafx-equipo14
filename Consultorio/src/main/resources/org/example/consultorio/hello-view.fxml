<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.*?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>

<VBox alignment="CENTER" prefHeight="500.0" prefWidth="700.0" spacing="10" style="-fx-background-color: #f4f4f4;" xmlns="http://javafx.com/javafx/17.0.12" xmlns:fx="http://javafx.com/fxml/1" fx:controller="org.example.consultorio.HelloController">
    <padding>
        <Insets bottom="15.0" left="15.0" right="15.0" top="15.0" />
    </padding>

    <Label style="-fx-font-size: 22px; -fx-font-weight: bold; -fx-text-fill: #2c3e50;" text="Gestión de Pacientes - Consultorio" />

    <HBox spacing="15" VBox.vgrow="ALWAYS">
        <VBox spacing="10" style="-fx-background-color: white; -fx-padding: 15; -fx-border-color: #ddd; -fx-border-radius: 5;">
            <Label style="-fx-font-weight: bold;" text="Datos del Paciente" />
            <GridPane hgap="10" vgap="10">
                <Label text="CURP:" GridPane.columnIndex="0" GridPane.rowIndex="0" />
                <TextField fx:id="txtCurp" GridPane.columnIndex="1" GridPane.rowIndex="0" />

                <Label text="Nombre:" GridPane.columnIndex="0" GridPane.rowIndex="1" />
                <TextField fx:id="txtNombre" GridPane.columnIndex="1" GridPane.rowIndex="1" />

                <Label text="Edad:" GridPane.columnIndex="0" GridPane.rowIndex="2" />
                <TextField fx:id="txtEdad" GridPane.columnIndex="1" GridPane.rowIndex="2" />

                <Label text="Teléfono:" GridPane.columnIndex="0" GridPane.rowIndex="3" />
                <TextField fx:id="txtTelefono" GridPane.columnIndex="1" GridPane.rowIndex="3" />

                <Label text="Alergias:" GridPane.columnIndex="0" GridPane.rowIndex="4" />
                <TextField fx:id="txtAlergias" GridPane.columnIndex="1" GridPane.rowIndex="4" />
            </GridPane>

            <Separator />
            <Button onAction="#onBtnGuardarClick" mnemonicParsing="false" prefWidth="150" text="Guardar Nuevo" />
            <Button onAction="#onBtnActualizarClick" mnemonicParsing="false" prefWidth="150" text="Actualizar Datos" />
            <Button onAction="#limpiarCampos" mnemonicParsing="false" prefWidth="150" text="Limpiar Campos" />

            <HBox spacing="5">
                <Button onAction="#onBtnEstatusClick" mnemonicParsing="false" text="Cambiar Estatus" />
                <Button onAction="#onBtnEliminarClick" mnemonicParsing="false" text="Eliminar" />
            </HBox>
        </VBox>

        <HBox HBox.hgrow="ALWAYS">
            <TableView fx:id="tablePacientes" HBox.hgrow="ALWAYS">
                <columns>
                    <TableColumn fx:id="colCurp" prefWidth="100" text="CURP" />
                    <TableColumn fx:id="colNombre" prefWidth="150" text="Nombre" />
                    <TableColumn fx:id="colEstatus" prefWidth="80" text="Estatus" />
                </columns>
            </TableView>
        </HBox>
    </HBox>

    <HBox spacing="20">
        <Label fx:id="lblActivos" style="-fx-text-fill: green; -fx-font-weight: bold;" text="Activos: 0" />
        <Label fx:id="lblInactivos" style="-fx-text-fill: red; -fx-font-weight: bold;" text="Inactivos: 0" />
    </HBox>
</VBox>