<?xml version="1.0" encoding="UTF-8"?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>

<VBox spacing="10" xmlns:fx="http://javafx.com/fxml" fx:controller="org.example.consultorio.HelloController">

    <Label text="DIRECTORIO DE PACIENTES" />

    <HBox spacing="10">
        <VBox spacing="5">
            <TextField fx:id="txtCurp" promptText="CURP" />
            <TextField fx:id="txtNombre" promptText="Nombre Completo" />
            <TextField fx:id="txtEdad" promptText="Edad" />
            <TextField fx:id="txtTelefono" promptText="Teléfono" />
            <TextField fx:id="txtAlergias" promptText="Alergias" />

            <Button text="Guardar" onAction="#onBtnGuardarClick" />
            <Button text="Actualizar" onAction="#onBtnActualizarClick" />
            <Button text="Limpiar" onAction="#limpiarCampos" />
        </VBox>

        <VBox spacing="5">
            <TableView fx:id="tablePacientes" prefWidth="400">
                <columns>
                    <TableColumn fx:id="colCurp" text="CURP" prefWidth="100" />
                    <TableColumn fx:id="colNombre" text="Nombre" prefWidth="200" />
                    <TableColumn fx:id="colEstatus" text="Estatus" prefWidth="100" />
                </columns>
            </TableView>

            <HBox spacing="10">
                <Button text="Cambiar Estatus" onAction="#onBtnEstatusClick" />
                <Button text="Eliminar" onAction="#onBtnEliminarClick" />
            </HBox>
        </VBox>
    </HBox>

    <HBox spacing="20">
        <Label fx:id="lblActivos" text="Activos: 0" />
        <Label fx:id="lblInactivos" text="Inactivos: 0" />
    </HBox>

</VBox>